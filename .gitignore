# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local
.claude

# Playwright
test-results/
playwright-report/
playwright/.cache/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Claude
.claude

# ML artifacts
data/selfplay/
data/ama-selfplay/
python/checkpoints/
python/.venv/
python/__pycache__/
python/**/__pycache__/

# Eval harness output (local accumulation, not committed)
data/eval-runs/

# ama WASM glue: only ama.js is regenerated; ama.d.ts is the hand-written
# type stub and stays in git so the loader typechecks even before a build.
src/ai/wasm-ama/_glue/ama.js
src/ai/wasm-ama/_glue/ama-gtr.js

# Tauri build artifacts
src-tauri/target/

# Tauri-generated schema files (regenerated on tauri build / dev)
src-tauri/gen/schemas/

# Note: src-tauri/gen/android/ is committed so CI can build without
# `tauri android init` (which would overwrite signing/customizations
# in app/build.gradle.kts). The directory has its own .gitignore that
# excludes build/, .gradle/, jniLibs/*.so, tauri.properties, etc.

# Android signing (defensive: keystore/properties never in git)
*.jks
*.keystore
key.properties

# License collection artifacts (regenerated by scripts/collect-licenses.sh)
third-party/

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
.env*
!.env.example
