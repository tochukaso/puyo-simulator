{
  "name": "puyo-simulator",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:ama-wasm": "bash scripts/build-ama-wasm.sh",
    "build:ama-native": "bash scripts/build-ama-native.sh",
    "build:ama-native:all": "bash scripts/build-ama-native.sh --all-targets",
    "gen:ama-golden": "tsx scripts/gen-ama-golden.ts",
    "bench:ama": "tsx scripts/bench-ama.ts",
    "lint": "eslint . --ext ts,tsx",
    "format": "prettier --write .",
    "preview": "npm run build && wrangler dev",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "e2e": "playwright test",
    "selfplay": "tsx scripts/selfplay.ts",
    "ama-selfplay": "tsx scripts/ama-selfplay.ts",
    "eval": "tsx scripts/eval-ai.ts",
    "deploy": "npm run build && wrangler deploy",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:dev:android": "tauri android dev",
    "tauri:build": "tauri build",
    "tauri:build:android": "tauri android build",
    "licenses:collect": "bash scripts/collect-licenses.sh",
    "licenses:check": "license-checker --production --failOn 'GPL;AGPL;LGPL'"
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.22.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.33.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.1",
    "@tensorflow/tfjs-node": "^4.22.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "license-checker": "^25.0.1",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.85.0"
  }
}
