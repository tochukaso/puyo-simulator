<!doctype html>
<html><head><meta charset="utf-8"><title>Third-party Licenses (Rust)</title></head>
<body>
<h1>Third-party Licenses (Rust)</h1>
{{#each licenses}}
<h2>{{name}} ({{id}})</h2>
<p>Used by: {{#each used_by}}{{crate.name}} {{crate.version}}{{#unless @last}}, {{/unless}}{{/each}}</p>
<pre>{{text}}</pre>
{{/each}}
</body></html>
