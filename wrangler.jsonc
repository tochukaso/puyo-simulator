{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "puyo-simulator",
  "compatibility_date": "2026-04-26",
  "workers_dev": true,
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
